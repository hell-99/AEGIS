{
  "name": "Ensemble Consensus Block Response",
  "description": "Automated response when 2+ detectors vote to block an IP",
  "triggers": ["ENSEMBLE-BLOCK"],
  "severity": "CRITICAL",
  "nist": { "function": "RESPOND", "category": "RS.MI-2", "description": "Incident containment executed" },
  "steps": [
    { "id": "enrich",      "action": "enrich_ip",       "description": "Query IP reputation via AbuseIPDB" },
    { "id": "log",         "action": "audit_log",        "description": "Log to SHA-256 audit ledger" },
    { "id": "notify",      "action": "notify",           "description": "Send CRITICAL severity alert" },
    { "id": "nist_map",    "action": "nist_map",         "description": "Map to NIST CSF RS.MI-2" },
    { "id": "escalate",    "action": "escalate",         "description": "Check for subnet-level escalation" },
    { "id": "report",      "action": "generate_report",  "description": "Save incident JSON report" },
    { "id": "close_case",  "action": "update_case",      "status": "CONTAINED", "description": "Mark case as contained" }
  ]
}
